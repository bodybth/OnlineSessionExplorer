<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Online Session Explorer"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tv_server_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Stopped"
            android:textSize="13sp"
            android:textColor="@color/color_offline"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- URL Card (visible when running) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tv_url"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="http://192.168.1.1:8001"
                android:textSize="14sp"
                android:textColor="@color/color_accent"
                android:fontFamily="monospace"
                android:clickable="true"
                android:focusable="true" />

            <ImageButton
                android:id="@+id/btn_copy_url"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_share"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_muted"
                android:contentDescription="Copy URL" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_toggle_server"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Start Server"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/color_start"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/btn_clear_logs"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Clear"
            android:textColor="@color/text_muted"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>

    <!-- Log output -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <ScrollView
            android:id="@+id/scroll_logs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:overScrollMode="ifContentScrolls"
            android:scrollbarStyle="insideOverlay">

            <TextView
                android:id="@+id/tv_logs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_log"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:text="" />
        </ScrollView>
    </androidx.cardview.widget.CardView>

</LinearLayout>
